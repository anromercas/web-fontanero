---
import { business } from '../data/business';

interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

const addressQuery = encodeURIComponent(
  `${business.address.streetAddress}, ${business.address.postalCode} ${business.address.addressLocality}`
);
const mapSrc = `https://www.google.com/maps?q=${addressQuery}&output=embed`;
const mapTitle = `Ubicación de ${business.name} en ${business.address.streetAddress}, ${business.address.addressLocality}`;
---
<iframe
  src={mapSrc}
  width="100%"
  height="400"
  style="border:0;"
  allowfullscreen
  loading="lazy"
  referrerpolicy="no-referrer-when-downgrade"
  title={mapTitle}
  class={`rounded-2xl ${className}`}
></iframe>
