---
import { business } from '../data/business';

interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Negocio de área de servicio sin dirección pública: el mapa se centra en la
// ficha del negocio buscándola por su nombre exacto en Google Maps.
const mapQuery = encodeURIComponent(`${business.name}, ${business.address.addressLocality}`);
const mapSrc = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
const mapTitle = `Ficha de ${business.name} en Google Maps`;
---
<iframe
  src={mapSrc}
  width="100%"
  height="400"
  style="border:0;"
  allowfullscreen
  loading="lazy"
  referrerpolicy="no-referrer-when-downgrade"
  title={mapTitle}
  class={`rounded-2xl ${className}`}
></iframe>
